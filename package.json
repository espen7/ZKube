{
  "name": "zkube",
  "private": true,
  "version": "0.1.0",
  "license": "MIT",
  "type": "module",
  "main": "dist-electron/main/index.cjs",
  "scripts": {
    "dev": "vite",
    "build": "npm run build:renderer && npm run build:electron && npm run package:win",
    "build:renderer": "vite build --base ./",
    "build:electron": "npm run build:electron:main && npm run build:electron:preload",
    "build:electron:main": "vite build --mode electron-main",
    "build:electron:preload": "vite build --mode electron-preload",
    "package:win": "electron-builder --config electron-builder.yml",
    "typecheck": "tsc --noEmit",
    "test:unit": "vitest run tests/domain tests/renderer",
    "test:e2e": "npm run build:renderer && npm run build:electron && playwright test tests/e2e --pass-with-no-tests"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "monaco-editor": "^0.55.1",
    "node-zookeeper-client": "^1.1.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.7.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "electron": "42.0.1",
    "electron-builder": "^26.8.1",
    "jsdom": "^29.1.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.12",
    "vitest": "^4.1.6"
  }
}
